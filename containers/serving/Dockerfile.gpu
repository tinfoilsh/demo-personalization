# serving image — GPU (real multi-LoRA serving). Used once the H200 is available;
# point the serving container's build at this file. Stock vLLM; holds the base
# model + every user's finished adapter, with runtime LoRA loading so the control
# server can hot-load new adapters without a restart.
#
# vLLM is PINNED to v0.22.0 — the exact image Tinfoil's prod Qwen enclave runs
# under CC, so it's a known-good serve path on the H200. We serve Llama because
# Qwen3-4B-Instruct-2507 (Qwen3ForCausalLM) produces deterministic garbage through
# vLLM on this CC box — independent of vLLM version, attention backend, eager mode,
# or CUDA graphs — while transformers serves the same weights fine and Llama serves
# correctly on the identical setup. If bumping vLLM or the model, first verify a
# coherent greedy /v1/chat/completions of "capital of France" → Paris.
FROM vllm/vllm-openai:v0.22.0@sha256:0fec7ec5f3e6bc168e54899935fb0557da908a4832a1dbc88e2debcf2f889416

ENV VLLM_ALLOW_RUNTIME_LORA_UPDATING=True
ENV NVIDIA_VISIBLE_DEVICES=0

# Bridge prod's gated-Llama secret (LLAMA_HF_TOKEN) to the HF_TOKEN vLLM reads,
# then exec `vllm serve`.
COPY containers/serving/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

EXPOSE 8000
# --gpu-memory-utilization kept low so the trainer's rollout vLLM fits on the same
# H200 (see personalization.md §4). Adapters are loaded at runtime, so they are
# NOT baked into this (attested) image — they're private state on /state.
CMD ["meta-llama/Llama-3.1-8B-Instruct", \
     "--enable-lora", \
     "--max-lora-rank", "32", \
     "--max-loras", "4", \
     "--max-cpu-loras", "16", \
     "--gpu-memory-utilization", "0.4"]
